+def upsample_by_repeat(hidden_states, prune_idxs):
+    device = hidden_states.device
+
+    if not torch.is_tensor(prune_idxs):
+        prune_idxs = torch.tensor(prune_idxs, device=device)
+    else:
+        prune_idxs = prune_idxs.to(device)
+    prune_idxs, _ = torch.sort(prune_idxs)
+
+    N = hidden_states.size(0)
+    L = N + prune_idxs.size(0)
+
+    keep_mask = torch.ones(L, dtype=torch.bool, device=device)
+    keep_mask[prune_idxs] = False
+    keep_idxs = torch.arange(L, device=device)[keep_mask]
+
+    order = torch.zeros(L, dtype=torch.long, device=device)
+    order[keep_idxs] = torch.arange(N, device=device)
+
+    left_keep_idx = order.cummax(dim=0)[0]
+    full = hidden_states[left_keep_idx]
+    return full
+
+
+
+
+def stride_prune(image_embeds, threshold_sim=0.7, threshold_entropy=0.3):
+    embeds = image_embeds.squeeze(1) if image_embeds.dim() == 3 else image_embeds
+    N = embeds.shape[0]
+
+    embeds_norm = embeds / (torch.norm(embeds, dim=-1, keepdim=True) + 1e-12)
+    valid_pairs = torch.arange(N - 1, device=image_embeds.device)
+    sim = (embeds_norm[valid_pairs] * embeds_norm[valid_pairs + 1]).sum(dim=-1)
+    mean_sim = sim.mean()
+    mean_entropy = torch.var(image_embeds, dim=-1).mean()
+
+    stride = 2 if (mean_sim > threshold_sim and mean_entropy < threshold_entropy) else 1
+    mask = torch.zeros(N, dtype=torch.bool, device=image_embeds.device)
+    mask[::stride] = True
+
+    return mask

